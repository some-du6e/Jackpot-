{
  "manifest_version": 3,
  "name": "Jackpot+",
  "description": "Removes the \"gambling\" theme from jackpot and overall makes the ux better",
  "version": "1.0.0",
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://jackpot.hackclub.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg"],
      "matches": ["https://jackpot.hackclub.com/*"]
    }
  ],
  "permissions": ["storage"]
}
