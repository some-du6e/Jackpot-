{
  "manifest_version": 3,
  "name": "Jackpot+",
  "description": "Removes the \"gambling\" theme from jackpot and overall makes the ux better",
  "version": "1.0.0",
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Jackpot+ Settings"
  },
  "content_scripts": [
    {
      "matches": ["https://jackpot.hackclub.com/*"],
      "js": [
        "components/cleanup.js",
        "components/styles.js",
        "components/settings.js",
        "components/shop.js",
        "components/toolbar.js",
        "components/deck.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg", "page-script.js", "injected-styles.css"],
      "matches": ["https://jackpot.hackclub.com/*"]
    }
  ],
  "permissions": ["storage", "scripting"],
  "host_permissions": ["https://jackpot.hackclub.com/*"]
}
